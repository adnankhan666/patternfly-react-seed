# Google Gemini API Key for AI Integration
# Get your API key from: https://aistudio.google.com/app/apikey
# IMPORTANT: Keep this secret! Never commit to git
GEMINI_API_KEY=your_gemini_api_key_here

# API Server Configuration
API_PORT=3001
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:9000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/odh-workflows

# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# IMPORTANT: Use a strong, unique secret in production!
JWT_SECRET=your_strong_jwt_secret_here_use_command_above_to_generate
JWT_EXPIRES_IN=24h

# Seeding
AUTO_SEED=true
